<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Hermetic NuGet configuration. The <clear /> entries force NuGet to ignore
    inherited sources from user-level (%APPDATA%\NuGet\NuGet.Config) or
    machine-level configs so this template restores from nuget.org only —
    no surprises from whatever feeds the adopter has configured locally.
    Adp.Agent and its dependencies live on nuget.org under the ai-manifests
    organization.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
